    {
      "id": "librechat",
      "label": "LibreChat",
      "version": "0.7.4",
      "description": "Multi-provider AI chat UI. Connect to OpenAI, Anthropic, Ollama, and more. The best free ChatGPT alternative.",
      "category": "ai",
      "website": "https://librechat.ai",
      "source": { "type": "git", "url": "https://github.com/danny-avila/LibreChat.git", "repo": "danny-avila/LibreChat", "branch": "main", "sha256": "" },
      "runtime": { "type": "native", "engine": "node", "version": "20.14.0" },
      "install": {
        "setup": ["npm install", "npm run build"],
        "startCommand": "npm start",
        "workingDir": "source"
      },
      "ports": [{ "port": 3080, "label": "Web UI", "protocol": "http" }],
      "env": [
        { "key": "HOST", "label": "Host", "defaultValue": "0.0.0.0" },
        { "key": "PORT", "label": "Port", "defaultValue": "3080" },
        { "key": "MONGO_URI", "label": "MongoDB URI", "defaultValue": "mongodb://localhost:27017/LibreChat" }
      ],
      "secrets": [
        { "key": "OPENAI_API_KEY", "label": "OpenAI API Key", "example": "sk-..." },
        { "key": "ANTHROPIC_API_KEY", "label": "Anthropic API Key", "example": "sk-ant-..." }
      ],
      "healthCheck": { "path": "/", "expectedStatus": 200, "timeoutMs": 10000 },
      "minRamMB": 512,
      "minStorageMB": 1000,
      "tags": ["ai", "chat", "llm", "openai", "claude"]
    },
