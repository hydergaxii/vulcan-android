<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- External storage (/sdcard/Vulcan) — for sharing backup ZIPs, APKs etc. -->
    <external-path name="vulcan_root" path="Vulcan/" />

    <!-- External files dir — app-specific external storage -->
    <external-files-path name="external_files" path="." />

    <!-- Internal cache — for temporary file sharing -->
    <cache-path name="cache" path="." />
</paths>
